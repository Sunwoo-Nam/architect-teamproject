<mxfile host="app.diagrams.net" agent="Claude">
  <diagram name="Context Diagram (arch-with-ai 기반)" id="context-diagram-internal">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" parent="1" vertex="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rotatable=0;fontSize=18;fontStyle=1;" value="Ondevice Agentic Platform — System Context Diagram&#10;(arch-with-ai 관점: 내부 IDS/MAF · 외부 LLM/DPA/Peer/Ext API)">
          <mxGeometry x="400" y="20" width="900" height="50" as="geometry" />
        </mxCell>

        <!-- Person: User -->
        <mxCell id="user" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;Person&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:15px;&quot;&gt;사용자 (User)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Android 폰 소유자.&lt;br&gt;권한을 위임하고, 일상 활동으로&lt;br&gt;묵시적 Intent를 표출하며,&lt;br&gt;협상 결과를 승인한다.&lt;/font&gt;">
          <mxGeometry x="720" y="100" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- Focus System: Ondevice Agentic Platform (container with IDS + MAF) -->
        <mxCell id="platform" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0A4D86;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=top;arcSize=8;strokeWidth=2;dashed=0;" value="&lt;i style=&quot;font-size:11px;&quot;&gt;&amp;laquo;System (focus)&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;b style=&quot;font-size:18px;&quot;&gt;Ondevice Agentic Platform (Android)&lt;/b&gt;">
          <mxGeometry x="540" y="380" width="600" height="260" as="geometry" />
        </mxCell>

        <!-- Inner: IDS -->
        <mxCell id="ids" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0A4D86;fontColor=#0A4D86;fontSize=12;align=center;verticalAlign=middle;arcSize=12;strokeWidth=2;" value="&lt;b style=&quot;font-size:13px;&quot;&gt;IDS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Intent Driven Secretary&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;기기 활동 모니터링 ·&lt;br&gt;Intent 감지 / 라우팅&lt;br&gt;(Zero-claw 기반)&lt;/font&gt;">
          <mxGeometry x="570" y="450" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- Inner: Multi-Agent Framework -->
        <mxCell id="maf" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0A4D86;fontColor=#0A4D86;fontSize=12;align=center;verticalAlign=middle;arcSize=12;strokeWidth=2;" value="&lt;b style=&quot;font-size:13px;&quot;&gt;Multi-Agent Framework&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Orchestrator&lt;br&gt;↓&lt;br&gt;Meta Agent (= PPA)&lt;br&gt;↓&lt;br&gt;Sub-Agent (동적 생성 포함)&lt;/font&gt;">
          <mxGeometry x="860" y="450" width="250" height="160" as="geometry" />
        </mxCell>

        <!-- External: 상대방 PPA -->
        <mxCell id="opponent_ppa" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;External System&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:14px;&quot;&gt;상대방 PPA&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;(상대방 기기의&lt;br&gt;Personal Proxy Agent)&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;A2A 협상 상대 엔드포인트&lt;/font&gt;">
          <mxGeometry x="100" y="430" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- External: DPA -->
        <mxCell id="dpa" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;External System&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:14px;&quot;&gt;Device Proxy Agent (DPA)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;세탁기 · TV · 냉장고 등&lt;br&gt;사용자 소유 가전&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;상태/스케줄 정보 제공&lt;/font&gt;">
          <mxGeometry x="1340" y="100" width="260" height="160" as="geometry" />
        </mxCell>

        <!-- External: 외부 서비스 API -->
        <mxCell id="ext_api" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;External System&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:14px;&quot;&gt;외부 서비스 API&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;숙박 · 교통 · 식당 ·&lt;br&gt;캘린더 · 결제 등&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Sub-Agent의 Tool로 호출&lt;/font&gt;">
          <mxGeometry x="1340" y="430" width="260" height="160" as="geometry" />
        </mxCell>

        <!-- External: 온디바이스 LLM -->
        <mxCell id="ondevice_llm" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;External System&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:14px;&quot;&gt;온디바이스 LLM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;경량 추론 모델&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;IDS · Meta Agent ·&lt;br&gt;Sub-Agent용&lt;/font&gt;">
          <mxGeometry x="380" y="800" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- External: 서버 LLM -->
        <mxCell id="server_llm" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;External System&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:14px;&quot;&gt;서버 LLM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;고성능 추론 모델&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Orchestrator용&lt;br&gt;(Task Planning · Agent 생성)&lt;/font&gt;">
          <mxGeometry x="1060" y="800" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- Edge: User -> Platform (down) -->
        <mxCell id="e_user_to_platform" parent="1" edge="1" source="user" target="platform" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;edgeStyle=orthogonalEdgeStyle;exitX=0.4;exitY=1;exitDx=0;exitDy=0;entryX=0.4;entryY=0;entryDx=0;entryDy=0;" value="기기 사용 행동&#10;(묵시적 Intent)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge: Platform -> User (up) -->
        <mxCell id="e_platform_to_user" parent="1" edge="1" source="platform" target="user" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;edgeStyle=orthogonalEdgeStyle;exitX=0.6;exitY=0;exitDx=0;exitDy=0;entryX=0.6;entryY=1;entryDx=0;entryDy=0;" value="Intent 감지 알림&#10;협상 결과 제시">
          <mxGeometry relative="1" as="geometry" />
