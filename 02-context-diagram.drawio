          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge: Platform <-> DPA -->
        <mxCell id="e_platform_dpa" parent="1" edge="1" source="platform" target="dpa" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.15;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" value="컨텍스트 정보 요청">
          <mxGeometry relative="1" as="geometry" />
