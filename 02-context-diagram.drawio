        <!-- Edge: Platform <-> 상대방 PPA (A2A, red) -->
        <mxCell id="e_platform_opponent" parent="1" edge="1" source="platform" target="opponent_ppa" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeWidth=2.5;strokeColor=#B85450;fontSize=12;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" value="A2A 프로토콜&#10;(협상 메시지)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge: Platform <-> DPA -->
        <mxCell id="e_platform_dpa" parent="1" edge="1" source="platform" target="dpa" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" value="컨텍스트 정보 요청">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge: Platform <-> 외부 서비스 API -->
        <mxCell id="e_platform_extapi" parent="1" edge="1" source="platform" target="ext_api" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" value="예약 · 실행 API 호출&#10;(Sub-Agent Tool)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge: Platform <-> 온디바이스 LLM -->
        <mxCell id="e_platform_ondevice" parent="1" edge="1" source="platform" target="ondevice_llm" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;edgeStyle=orthogonalEdgeStyle;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" value="LLM 추론 요청&#10;(IDS · MA · SA)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge: Platform <-> 서버 LLM -->
        <mxCell id="e_platform_serverllm" parent="1" edge="1" source="platform" target="server_llm" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;edgeStyle=orthogonalEdgeStyle;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" value="Task 분해 ·&#10;Agent 생성 요청">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend_box" parent="1" vertex="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=0;marginBottom=0;swimlaneFillColor=#ffffff;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" value="Legend">
          <mxGeometry x="100" y="800" width="240" height="180" as="geometry" />
        </mxCell>
        <mxCell id="lg_person" parent="legend_box" vertex="1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;overflow=hidden;rotatable=0;fontSize=11;html=1;fontColor=#08427B;fontStyle=1;" value="▭ 진청 — «Person»">
          <mxGeometry y="30" width="240" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lg_focus" parent="legend_box" vertex="1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;overflow=hidden;rotatable=0;fontSize=11;html=1;fontColor=#1168BD;fontStyle=1;" value="▭ 청 — «System (focus)»">
          <mxGeometry y="52" width="240" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lg_ext" parent="legend_box" vertex="1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;overflow=hidden;rotatable=0;fontSize=11;html=1;fontColor=#666666;fontStyle=1;" value="▭ 회색 — «External System»">
          <mxGeometry y="74" width="240" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lg_sep" parent="legend_box" vertex="1" style="line;strokeWidth=1;fillColor=none;strokeColor=#bbbbbb;" value="">
