        <mxCell id="lg_arrow_normal" parent="legend_box" vertex="1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;overflow=hidden;rotatable=0;fontSize=11;html=1;fontColor=#444444;" value="→ 회색 — 외부 상호작용">
