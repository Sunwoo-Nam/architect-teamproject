        <!-- Edge: Platform <-> 외부 서비스 API -->
        <mxCell id="e_platform_extapi" parent="1" edge="1" source="platform" target="ext_api" style="endArrow=classic;startArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444;fontSize=11;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.45;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" value="예약 · 실행 API 호출&#10;(Sub-Agent Tool)">
