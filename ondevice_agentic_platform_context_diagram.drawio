        </mxCell>
        <mxCell id="user_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;Person&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:15px;&quot;&gt;User A&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Owns the platform instance.&lt;br&gt;Delegates authority, provides intent&lt;br&gt;through daily activity, approves&lt;br&gt;final proposals.&lt;/font&gt;" vertex="1">
          <mxGeometry height="160" width="240" x="700" y="50" as="geometry" />
        </mxCell>
        <mxCell id="user_b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;Person&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:15px;&quot;&gt;User B&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Counterpart user; owns a peer&lt;br&gt;platform instance.&lt;br&gt;Participates in negotiation.&lt;/font&gt;" vertex="1">
          <mxGeometry height="160" width="200" x="1840" y="410" as="geometry" />
        </mxCell>
        <mxCell id="focus_system" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0A4D86;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:11px;&quot;&gt;&amp;laquo;System (focus)&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:18px;&quot;&gt;Ondevice Agentic Platform&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:12px;&quot;&gt;(for User A)&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;Personal AI agents that autonomously coordinate the user&#39;s&lt;br&gt;everyday micro-decisions via &lt;b&gt;intent detection (IDS)&lt;/b&gt;,&lt;br&gt;&lt;b&gt;multi-agent orchestration (MAF)&lt;/b&gt;, &lt;b&gt;dynamic agent/tool spawning&lt;/b&gt;,&lt;br&gt;and &lt;b&gt;peer-to-peer A2A negotiation&lt;/b&gt;.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;i&gt;Scope: Android phone + user&#39;s device ecosystem (TV · washer · fridge …)&lt;br&gt;+ product cloud backend (LLM model &amp;amp; Agent Build Service)&lt;/i&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="290" width="550" x="530" y="335" as="geometry" />
        </mxCell>
        <mxCell id="ext_messaging" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;External System&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:14px;&quot;&gt;Messaging &amp;amp;&lt;br&gt;Communication Apps&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;KakaoTalk · SMS · Email ·&lt;br&gt;calendar / app events.&lt;br&gt;Source of signals that IDS&lt;br&gt;observes to detect intent.&lt;/font&gt;" vertex="1">
