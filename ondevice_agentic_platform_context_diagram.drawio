        <mxCell id="ext_thirdparty" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;align=center;verticalAlign=middle;arcSize=8;strokeWidth=2;" value="&lt;i style=&quot;font-size:10px;&quot;&gt;&amp;laquo;External System&amp;raquo;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:14px;&quot;&gt;3rd-party Service APIs&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Accommodation · flight · calendar ·&lt;br&gt;maps · payment providers.&lt;br&gt;Invoked by Sub-Agents as tools&lt;br&gt;to actually execute tasks.&lt;/font&gt;" vertex="1">
