<mxfile host="Electron">
  <diagram id="banan1" name="방안1 출구제거">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" parent="1" vertex="1" value="라운드 흐름 — 방안 1 (출구 제거 / Filter-at-Egress)" style="text;html=1;fontSize=14;fontStyle=1;align=left;">
          <mxGeometry x="40" y="20" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="boundary1" parent="1" vertex="1" value="신뢰 내부 (단말)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;" >
          <mxGeometry x="40" y="60" width="560" height="500" as="geometry" />
        </mxCell>
        <mxCell id="note1" parent="1" vertex="1" value="세션 시작 — 분류만 (변환 없음)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;dashed=1;">
          <mxGeometry x="70" y="100" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="raw1" parent="1" vertex="1" value="원본 (로컬)&lt;br&gt;정확 시간·예산·기기맥락" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;">
          <mxGeometry x="70" y="300" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="on1" parent="1" vertex="1" value="LLM-on (온디바이스·신뢰)&lt;br&gt;&lt;br&gt;판단 + 작성&lt;br&gt;(원본 그대로 사용)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;">
          <mxGeometry x="320" y="180" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="gate1" parent="1" vertex="1" value="EgressGate&lt;br&gt;(필터, 불완전)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;">
          <mxGeometry x="320" y="420" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cp1" parent="1" vertex="1" value="LLM-cp&lt;br&gt;(외부 상대)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;">
          <mxGeometry x="700" y="300" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ext1" parent="1" vertex="1" value="집 밖 (외부)" style="text;html=1;fontSize=12;fontStyle=2;align=center;fontColor=#82b366;">
          <mxGeometry x="700" y="270" width="180" height="20" as="geometry" />
        </mxCell>
        <mxCell id="e1a" parent="1" source="cp1" target="on1" edge="1" value="① 상대 메시지/캐묻기" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1b" parent="1" source="raw1" target="on1" edge="1" value="② 원본 제공" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1c" parent="1" source="on1" target="gate1" edge="1" value="③ 초안 (원본 섞일 수 있음)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1d" parent="1" source="gate1" target="cp1" edge="1" value="④ 필터 통과분&lt;br&gt;※누설 = 필터가 놓친 원본 조각" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;strokeColor=#b85450;fontColor=#b85450;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="banan2" name="방안2 사전변환">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title2" parent="1" vertex="1" value="라운드 흐름 — 방안 2 (사전 변환 / Transform-Upfront)" style="text;html=1;fontSize=14;fontStyle=1;align=left;">
          <mxGeometry x="40" y="20" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="boundary2" parent="1" vertex="1" value="신뢰 내부 (단말)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;">
          <mxGeometry x="40" y="60" width="640" height="580" as="geometry" />
        </mxCell>
        <mxCell id="note2" parent="1" vertex="1" value="세션 시작 1회 — 변환 후 원본 폐기" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;dashed=1;">
          <mxGeometry x="70" y="90" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="raw2" parent="1" vertex="1" value="원본 (로컬)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;">
          <mxGeometry x="70" y="140" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="pm2" parent="1" vertex="1" value="PrivacyMediator (+LLM-on)&lt;br&gt;(a) PII 토큰화&lt;br&gt;(c) 원본→사실값·폐기&lt;br&gt;(b) 정밀도 컴파일" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;">
          <mxGeometry x="280" y="120" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="v2" parent="1" vertex="1" value="PrivacyVault&lt;br&gt;토큰↔원본 매핑" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;">
          <mxGeometry x="300" y="250" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="on2" parent="1" vertex="1" value="LLM-on (협상 추론)&lt;br&gt;&lt;br&gt;판단 + 작성&lt;br&gt;(안전형만 사용)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;">
          <mxGeometry x="300" y="360" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="gate2" parent="1" vertex="1" value="EgressGate (검증)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;">
          <mxGeometry x="300" y="500" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cp2" parent="1" vertex="1" value="LLM-cp&lt;br&gt;(외부 상대)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;">
          <mxGeometry x="760" y="390" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ext2" parent="1" vertex="1" value="집 밖 (외부)" style="text;html=1;fontSize=12;fontStyle=2;align=center;fontColor=#82b366;">
          <mxGeometry x="760" y="360" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="e2a" parent="1" source="raw2" target="pm2" edge="1" value="원본" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2b" parent="1" source="pm2" target="v2" edge="1" value="PII 토큰 매핑 저장" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2c" parent="1" source="pm2" target="on2" edge="1" value="SafeScope (토큰·coarse 사실)&lt;br&gt;— 원본은 폐기" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2d" parent="1" source="cp2" target="on2" edge="1" value="① 상대 메시지/캐묻기" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2e" parent="1" source="on2" target="gate2" edge="1" value="② 메시지 (원본 없음)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2f" parent="1" source="gate2" target="cp2" edge="1" value="③ 통과&lt;br&gt;※거를 원본 자체가 경로에 없음" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=11;strokeColor=#82b366;fontColor=#1a7f37;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
