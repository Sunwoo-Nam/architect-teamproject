      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="DP11-α Sol.2 — On-Device Reactive Runtime&#10;(Orchestrator는 thin proxy + 새 도메인 첫 등장·폴백 시만 서버 LLM 호출)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="10" width="740" height="40" as="geometry" />
        </mxCell>

        <!-- On-device box (LARGE — dominant) -->
        <mxCell id="device-box" value="온디바이스 (Android) — 본체 decision-maker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;strokeWidth=2;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="730" height="755" as="geometry" />
        </mxCell>

        <!-- Server box (SMALLER — auxiliary) -->
