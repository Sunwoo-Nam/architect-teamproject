          <mxGeometry x="300" y="100" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- IDS -->
        <mxCell id="ids" value="IDS  (본 DP scope 외)&#10;━━━━━━━━━━━━━━━&#10;IntentEvent 생성 → Orchestrator로 전달&#10;{ intent_id, relation_label, target_intent_id, analysis_payload }" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="180" width="400" height="90" as="geometry" />
        </mxCell>

        <!-- Meta Agent Runtime (LARGE — dominant) -->
        <mxCell id="mar" value="Meta Agent Runtime  —  본체 decision-maker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;verticalAlign=top;fontStyle=1;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="710" height="370" as="geometry" />
        </mxCell>

        <!-- Skeleton Cache -->
        <mxCell id="mar-sc" value="Skeleton Cache&#10;도메인별 Skeleton 영속 보관&#10;(Orchestrator 발급, Cache hit 시 LLM 호출 X)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Policy Table -->
        <mxCell id="mar-pt" value="Policy Table  ★ 핵심 자료&#10;(이벤트, 라벨, 상태) → 액션 lookup&#10;━━━━━━━━━━━━━━━━━━━━━━━━&#10;⚙ 작성 주체: 서버 LLM이 Skeleton 발급 시&#10;   초기 룰셋 자동 생성 (사람 수작업 0)&#10;⚙ 점진 보강: 폴백 응답을 새 룰로 추가" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff4cc;strokeColor=#82b366;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="340" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Policy Updater -->
        <mxCell id="mar-pu" value="Policy Updater&#10;폴백 응답을&#10;새 룰로 추가" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="340" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- Reactive Decision Engine -->
        <mxCell id="mar-de" value="Reactive Decision Engine&#10;━━━━━━━━━━━━━━━━━━━━━━━━&#10;이벤트 수신 → Policy Table lookup → 즉시 액션&#10;(대부분 서버 LLM 호출 없이 온디바이스에서 종결)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b5e0a8;strokeColor=#5d8f4d;strokeWidth=2;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="475" width="460" height="80" as="geometry" />
        </mxCell>

        <!-- Resource Coordinator -->
        <mxCell id="mar-rc" value="Resource&#10;Coordinator&#10;(자원 lease 직렬화)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="475" width="190" height="80" as="geometry" />
        </mxCell>

        <!-- Event Log + Decision Log -->
        <mxCell id="mar-el" value="Event Log  +  Decision Log&#10;(영속 — 회복용 + QA-007 추적성 보강용)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
