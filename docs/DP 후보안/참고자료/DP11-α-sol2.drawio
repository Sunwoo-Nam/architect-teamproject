          <mxGeometry x="80" y="770" width="640" height="40" as="geometry" />
        </mxCell>

        <!-- Server: Orchestrator (Thin Proxy + Skeleton Generator + Fallback Resolver) -->
        <mxCell id="orch" value="Orchestrator  —  Thin Proxy&#10;━━ 대부분 routing only ━━" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontStyle=1;fontSize=11;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="200" width="290" height="370" as="geometry" />
        </mxCell>
        <mxCell id="orch-route" value="① Routing (대부분 IntentEvent)&#10;━━━&#10;Skeleton Cache 상태 확인 후 단순 전달&#10;서버 LLM 호출 없음" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="240" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="orch-sg" value="② Skeleton Generator (LLM 호출)&#10;━━━&#10;Cache miss 시: sub_agents + 초기 Policy Table 룰셋&#10;자동 생성 → Meta Agent Runtime에 발급&#10;(도메인당 1회)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="340" width="250" height="105" as="geometry" />
        </mxCell>
        <mxCell id="orch-fr" value="③ Policy Fallback Resolver (LLM 호출)&#10;━━━&#10;정책표 lookup miss 시: 일회성 해결안&#10;→ Policy Updater가 새 룰로 추가 (드물게)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="455" width="250" height="100" as="geometry" />
        </mxCell>

